{
  "sourceLanguage": "en",
  "strings": {
    "account_view.button.log_in_another_account": {
      "comment": "account_view.button.log_in_another_account",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log in to another account"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录其他账号"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入其他帳號"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "登入其他帳戶"
          }
        }
      }
    },
    "account_view.dialog_action.signup_again": {
      "comment": "account_view.dialog_action.signup_again",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create new account"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注册新帐号"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "註冊新帳號"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "註冊新帳戶"
          }
        }
      }
    },
    "account_view.dialog_message.account_not_exist": {
      "comment": "account_view.dialog_message.account_not_exist",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To ensure account security, accounts inactive for over a year with no activities are automatically removed.\nYou can create a new account to continue using our services."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为确保账号安全，超过一年未使用、並且无活动记录的账号会被自动清除。\n你可以注册新账号，继续使用我们的服务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為確保帳號安全，超過一年未使用、並且無活動紀錄的帳號會被自動清除。\n你可以註冊新帳號，繼續使用我們的服務。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "為確保帳戶安全，超過一年未使用、並且無活動紀錄的帳戶會被自動清除。\n你可以註冊新帳戶，繼續使用我們的服務。"
          }
        }
      }
    },
    "account_view.dialog_title.account_not_exist": {
      "comment": "account_view.dialog_title.account_not_exist",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We cannot find your account"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "抱歉，我们找不到这个账号"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "抱歉，我們找不到這個帳號"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "抱歉，我們找不到這個帳戶"
          }
        }
      }
    },
    "account_view.sub_title.sign_up": {
      "comment": "account_view.sub_title.sign_up",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let's get you started."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "加入会员，开始使用 Hikingbook"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "加入會員，開始使用 Hikingbook"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "加入會員，開始使用 Hikingbook"
          }
        }
      }
    },
    "account_view.subtitle.continue_this_account": {
      "comment": "account_view.subtitle.continue_this_account",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue with this account?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续使用此账号登录吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "繼續使用此帳號登入嗎？"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "繼續使用此帳戶登入嗎？"
          }
        }
      }
    },
    "account_view.terms_of_service_and_privacy_policy": {
      "comment": "account_view.terms_of_service_and_privacy_policy",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By continuing to use Hikingbook, you agree to our %@ and %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击登录或继续，即表示你同意 Hikingbook 的%@和%@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊登入或繼續，即表示你同意 Hikingbook 的%@和%@。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊登入或繼續，即表示你同意 Hikingbook 的%@和%@。"
          }
        }
      }
    },
